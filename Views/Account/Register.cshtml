@model ChoThueQuanAo.ViewModels.RegisterViewModel

@{
    ViewData["Title"] = "Đăng ký";
}

<h2>Đăng ký tài khoản</h2>

<form asp-action="Register" method="post">
    <div asp-validation-summary="All" class="text-danger"></div>

    <div class="mb-3">
        <label asp-for="FullName" class="form-label">Họ tên</label>
        <input asp-for="FullName" class="form-control" />
        <span asp-validation-for="FullName" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Email" class="form-label">Email</label>
        <input asp-for="Email" class="form-control" />
        <span asp-validation-for="Email" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Phone" class="form-label">Số điện thoại</label>
        <input asp-for="Phone" class="form-control" />
    </div>

    <div class="mb-3">
        <label asp-for="Address" class="form-label">Địa chỉ</label>
        <input asp-for="Address" class="form-control" />
    </div>

    <div class="mb-3">
        <label asp-for="Password" class="form-label">Mật khẩu</label>
        <div class="input-group">
            <input asp-for="Password" class="form-control" id="Password" />
            <button type="button" class="btn btn-outline-secondary" onclick="togglePassword()" id="eyeIcon1">
                👁
            </button>
        </div>
        <span asp-validation-for="Password" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="ConfirmPassword" class="form-label">Nhập lại mật khẩu</label>
        <div class="input-group">
            <input asp-for="ConfirmPassword" class="form-control" id="ConfirmPassword" />
            <button type="button" class="btn btn-outline-secondary" onclick="toggleConfirmPassword()" id="eyeIcon2">
                👁
            </button>
        </div>
        <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">Đăng ký</button>
    <a asp-action="Login" class="btn btn-secondary">Đăng nhập</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        function togglePassword() {
            var passwordInput = document.getElementById("Password");
            var icon = document.getElementById("eyeIcon1");

            if (passwordInput.type === "password") {
                passwordInput.type = "text";
                icon.innerText = "🙈";
            } else {
                passwordInput.type = "password";
                icon.innerText = "👁";
            }
        }

        function toggleConfirmPassword() {
            var confirmInput = document.getElementById("ConfirmPassword");
            var icon = document.getElementById("eyeIcon2");

            if (confirmInput.type === "password") {
                confirmInput.type = "text";
                icon.innerText = "🙈";
            } else {
                confirmInput.type = "password";
                icon.innerText = "👁";
            }
        }
    </script>
}