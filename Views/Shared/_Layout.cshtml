<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ChoThueQuanAo</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/ChoThueQuanAo.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
    <style>
        .ai-chat-widget {
            position: fixed;
            right: 24px;
            bottom: 24px;
            z-index: 1100;
            font-family: Arial, sans-serif;
        }
        .ai-chat-button {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 58px;
            height: 58px;
            border-radius: 50%;
            background-color: #0d6efd;
            color: #fff;
            border: none;
            box-shadow: 0 10px 24px rgba(13,110,253,0.2);
            cursor: pointer;
        }
        .ai-chat-button i { font-size: 20px; }
        .ai-chat-panel {
            width: 320px;
            max-width: calc(100vw - 32px);
            border-radius: 20px;
            box-shadow: 0 18px 40px rgba(0,0,0,0.15);
            background: #fff;
            overflow: hidden;
            margin-bottom: 12px;
        }
        .ai-chat-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 14px 16px;
            background: linear-gradient(135deg, #0d6efd, #6610f2);
            color: white;
        }
        .ai-chat-header span { font-weight: 700; }
        .ai-chat-messages {
            max-height: 300px;
            overflow-y: auto;
            padding: 12px 14px;
            background: #f8f9fa;
        }
        .ai-chat-message { margin-bottom: 12px; }
        .ai-chat-message.user { text-align: right; }
        .ai-chat-bubble {
            display: inline-block;
            padding: 10px 14px;
            border-radius: 18px;
            max-width: 84%;
            line-height: 1.5;
        }
        .ai-chat-message.user .ai-chat-bubble { background: #0d6efd; color: #fff; }
        .ai-chat-message.bot .ai-chat-bubble { background: #e9ecef; color: #212529; }
        .ai-chat-form {
            display: flex;
            gap: 8px;
            padding: 12px 14px 14px;
            background: #fff;
        }
        .ai-chat-form input {
            flex: 1;
            border-radius: 999px;
            border: 1px solid #ced4da;
        }
        .ai-chat-form button {
            border-radius: 999px;
            padding: 0 16px;
        }
        .ai-chat-close {
            background: transparent;
            border: none;
            color: white;
            font-size: 18px;
            cursor: pointer;
        }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand fw-bold text-primary" asp-controller="Home" asp-action="Index">
                    <i class="fas fa-tshirt me-2"></i>ChoThueQuanAo
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarMain">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item"><a class="nav-link text-dark" asp-controller="Home" asp-action="Index">Home</a></li>
                        <li class="nav-item"><a class="nav-link text-dark" asp-controller="Product" asp-action="Index">Sản phẩm</a></li>
                        <li class="nav-item">
                            <a class="nav-link text-danger fw-bold" asp-controller="Promotion" asp-action="Index">
                                <i class="fas fa-gift me-1"></i> Khuyến mãi
                            </a>
                        </li>
                        @if (User.Identity != null && User.Identity.IsAuthenticated) {
                            if (User.IsInRole("Admin") || User.IsInRole("Staff") || User.IsInRole("Manager")) {
                                <li class="nav-item border-start ms-2 ps-2"><a class="nav-link text-dark" asp-controller="Category" asp-action="Index">Danh mục SP</a></li>
                                <li class="nav-item"><a class="nav-link text-dark" asp-controller="Supplier" asp-action="Index">Nhà cung ứng</a></li>
                                <li class="nav-item"><a class="nav-link text-dark" asp-controller="RentalContract" asp-action="Index">Quản lý Hợp đồng</a></li>
                            } else {
                                <li class="nav-item"><a class="nav-link text-dark" asp-controller="RentalContract" asp-action="MyContracts">Hợp đồng của tôi</a></li>
                            }
                        }
                    </ul>
                    <ul class="navbar-nav align-items-center">
                        @{
                            var cart = Context.Session.GetString("Cart");
                            int count = string.IsNullOrEmpty(cart) ? 0 : cart.Split(',', StringSplitOptions.RemoveEmptyEntries).Length;
                        }
                        <li class="nav-item me-3">
                            <a class="nav-link position-relative" asp-controller="Cart" asp-action="Index">
                                <i class="fas fa-shopping-cart text-dark"></i> Giỏ hàng
                                @if (count > 0) {
                                    <span style="position:absolute; top:0; right:-10px; background:red; color:white; border-radius:50%; padding:2px 6px; font-size:10px;">@count</span>
                                }
                            </a>
                        </li>
                        @if (User.Identity != null && User.Identity.IsAuthenticated) {
                            <li class="nav-item"><span class="nav-link text-dark fw-bold">👋 @User.Identity.Name</span></li>
                            <li class="nav-item">
                                <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                                    <button type="submit" class="nav-link btn btn-link text-danger border-0" style="text-decoration: none;">Đăng xuất</button>
                                </form>
                            </li>
                        } else {
                            <li class="nav-item"><a class="nav-link text-dark" asp-controller="Account" asp-action="Login">Đăng nhập</a></li>
                            <li class="nav-item"><a class="nav-link text-dark" asp-controller="Account" asp-action="Register">Đăng ký</a></li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">@RenderBody()</main>
    </div>
    <footer class="border-top footer text-muted text-center mt-3">&copy; 2026 - ChoThueQuanAo</footer>

    <div class="ai-chat-widget">
        <div id="aiChatPanel" class="ai-chat-panel d-none">
            <div class="ai-chat-header">
                <span>AI Trợ lý</span>
                <button id="aiChatClose" class="ai-chat-close" title="Đóng">×</button>
            </div>
            <div id="aiChatMessages" class="ai-chat-messages">
                <div class="ai-chat-message bot">
                    <div class="ai-chat-bubble">Xin chào! Bạn có thể hỏi mình về thuê đồ, size, giá, cọc hoặc màu sắc.</div>
                </div>
            </div>
            <form id="aiChatForm" class="ai-chat-form">
                <input id="aiChatInput" type="text" placeholder="Gõ câu hỏi..." autocomplete="off" />
                <button type="submit" class="btn btn-primary">Gửi</button>
            </form>
        </div>
        <button id="aiChatToggle" class="ai-chat-button" title="Mở chat AI">
            <i class="fas fa-robot"></i>
        </button>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        const aiChatToggle = document.getElementById('aiChatToggle');
        const aiChatPanel = document.getElementById('aiChatPanel');
        const aiChatClose = document.getElementById('aiChatClose');
        const aiChatForm = document.getElementById('aiChatForm');
        const aiChatInput = document.getElementById('aiChatInput');
        const aiChatMessages = document.getElementById('aiChatMessages');

        function appendMessage(text, sender) {
            const message = document.createElement('div');
            message.className = 'ai-chat-message ' + sender;
            const bubble = document.createElement('div');
            bubble.className = 'ai-chat-bubble';
            bubble.textContent = text;
            message.appendChild(bubble);
            aiChatMessages.appendChild(message);
            aiChatMessages.scrollTop = aiChatMessages.scrollHeight;
        }

        aiChatToggle.addEventListener('click', () => {
            aiChatPanel.classList.toggle('d-none');
            if (!aiChatPanel.classList.contains('d-none')) {
                aiChatInput.focus();
            }
        });

        aiChatClose.addEventListener('click', () => {
            aiChatPanel.classList.add('d-none');
        });

        aiChatForm.addEventListener('submit', async (e) => {
            e.preventDefault();
            const question = aiChatInput.value.trim();
            if (!question) return;
            appendMessage(question, 'user');
            aiChatInput.value = '';

            try {
                const response = await fetch('/Chat/Ask', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                    body: new URLSearchParams({ message: question })
                });
                const data = await response.json();
                if (data.success) {
                    appendMessage(data.answer, 'bot');
                } else {
                    appendMessage('AI hiện không trả lời được câu hỏi này.', 'bot');
                }
            } catch (error) {
                appendMessage('Lỗi kết nối. Vui lòng thử lại sau.', 'bot');
            }
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>