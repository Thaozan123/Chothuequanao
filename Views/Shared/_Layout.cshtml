<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ChoThueQuanAo</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/ChoThueQuanAo.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand fw-bold text-primary" asp-controller="Home" asp-action="Index">
                    <i class="fas fa-tshirt me-2"></i>ChoThueQuanAo
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarMain">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item"><a class="nav-link text-dark" asp-controller="Home" asp-action="Index">Home</a></li>
                        <li class="nav-item"><a class="nav-link text-dark" asp-controller="Product" asp-action="Index">Sản phẩm</a></li>
                        <li class="nav-item">
                            <a class="nav-link text-danger fw-bold" asp-controller="Promotion" asp-action="Index">
                                <i class="fas fa-gift me-1"></i> Khuyến mãi
                            </a>
                        </li>
                        @if (User.Identity != null && User.Identity.IsAuthenticated) {
                            if (User.IsInRole("Admin") || User.IsInRole("Staff") || User.IsInRole("Manager")) {
                                <li class="nav-item border-start ms-2 ps-2"><a class="nav-link text-dark" asp-controller="Category" asp-action="Index">Danh mục SP</a></li>
                                <li class="nav-item"><a class="nav-link text-dark" asp-controller="Supplier" asp-action="Index">Nhà cung ứng</a></li>
                                <li class="nav-item"><a class="nav-link text-dark" asp-controller="RentalContract" asp-action="Index">Quản lý Hợp đồng</a></li>
                            } else {
                                <li class="nav-item"><a class="nav-link text-dark" asp-controller="RentalContract" asp-action="MyContracts">Hợp đồng của tôi</a></li>
                            }
                        }
                    </ul>
                    <ul class="navbar-nav align-items-center">
                        @{
                            var cart = Context.Session.GetString("Cart");
                            int count = string.IsNullOrEmpty(cart) ? 0 : cart.Split(',', StringSplitOptions.RemoveEmptyEntries).Length;
                        }
                        <li class="nav-item me-3">
                            <a class="nav-link position-relative" asp-controller="Cart" asp-action="Index">
                                <i class="fas fa-shopping-cart text-dark"></i> Giỏ hàng
                                @if (count > 0) {
                                    <span style="position:absolute; top:0; right:-10px; background:red; color:white; border-radius:50%; padding:2px 6px; font-size:10px;">@count</span>
                                }
                            </a>
                        </li>
                        @if (User.Identity != null && User.Identity.IsAuthenticated) {
                            <li class="nav-item"><span class="nav-link text-dark fw-bold">👋 @User.Identity.Name</span></li>
                            <li class="nav-item">
                                <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                                    <button type="submit" class="nav-link btn btn-link text-danger border-0" style="text-decoration: none;">Đăng xuất</button>
                                </form>
                            </li>
                        } else {
                            <li class="nav-item"><a class="nav-link text-dark" asp-controller="Account" asp-action="Login">Đăng nhập</a></li>
                            <li class="nav-item"><a class="nav-link text-dark" asp-controller="Account" asp-action="Register">Đăng ký</a></li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">@RenderBody()</main>
    </div>
    <footer class="border-top footer text-muted text-center mt-3">&copy; 2026 - ChoThueQuanAo</footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>