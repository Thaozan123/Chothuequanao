@model IEnumerable<ChoThueQuanAo.Models.RentalContract>

@{
    ViewData["Title"] = User.IsInRole("Admin") ? "Quản lý Hợp đồng" : "Hợp đồng của tôi";
    bool isAdmin = User.IsInRole("Admin");
}

<div class="container mt-4">
    <h2 class="text-primary fw-bold mb-4">
        <i class="fas fa-file-invoice-dollar me-2"></i>
        @(isAdmin ? "Danh sách tất cả Hợp đồng" : "Lịch sử thuê đồ của tôi")
    </h2>

    <div class="table-responsive shadow-sm rounded">
        <table class="table table-hover align-middle bg-white mb-0">
            <thead class="table-dark">
                <tr>
                    <th class="px-3">Mã HĐ</th>
                    @if (isAdmin) { <th>Khách hàng</th> }
                    <th>Ngày thuê</th>
                    <th>Ngày trả dự kiến</th>
                    <th class="text-end">Tổng tiền</th>
                    <th class="text-center">Trạng thái</th>
                    <th class="text-center">Chức năng</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="px-3 fw-bold text-primary">@item.ContractCode</td>
                            @if (isAdmin) { <td>@item.Customer?.FullName</td> }
                            <td>@item.StartDate.ToString("dd/MM/yyyy")</td>
                            <td>@item.ExpectedReturnDate.ToString("dd/MM/yyyy")</td>
                            <td class="text-end fw-bold">@item.TotalAmount.ToString("N0") đ</td>
                            <td class="text-center">
                                <span class="badge @(item.Status == "Active" ? "bg-success" : "bg-warning text-dark")">
                                    @item.Status
                                </span>
                            </td>
                            <td class="text-center">
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info text-white shadow-sm">
                                    <i class="fas fa-eye"></i> Chi tiết
                                </a>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="@(isAdmin ? 7 : 6)" class="text-center py-5 text-muted">
                            <i class="fas fa-folder-open fa-3x mb-3"></i>
                            <p>Bạn chưa có hợp đồng nào hết Vân ơi!</p>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css" />
}