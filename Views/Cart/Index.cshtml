@model List<ChoThueQuanAo.Models.Product>

@{
    ViewData["Title"] = "Giỏ hàng của bạn";
    // Giả định mặc định thuê 3 ngày để tính toán sơ bộ
    decimal subTotal = Model.Sum(p => p.RentalPricePerDay) * 3; 
}

<div class="container mt-4">
    <h2 class="text-primary fw-bold mb-4">🛒 Giỏ hàng của bạn</h2>

    @if (Model == null || !Model.Any())
    {
        <div class="alert alert-info shadow-sm">
            <p class="mb-0">Giỏ hàng của bạn đang trống. Hãy quay lại <a asp-controller="Product" asp-action="Index" class="fw-bold">Danh sách sản phẩm</a> để chọn đồ nhé!</p>
        </div>
    }
    else
    {
        <div class="row">
            <div class="col-md-8">
                <table class="table table-hover border shadow-sm bg-white rounded">
                    <thead class="table-dark">
                        <tr>
                            <th>Sản phẩm</th>
                            <th class="text-center">Size mặc định</th>
                            <th class="text-end">Giá thuê/ngày</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>
                                    <div class="d-flex align-items-center">
                                        @if (!string.IsNullOrEmpty(item.ImageUrl))
                                        {
                                            <img src="@item.ImageUrl" class="rounded me-2" style="width: 50px; height: 50px; object-fit: cover;" />
                                        }
                                        <span class="fw-bold">@item.Name</span>
                                    </div>
                                </td>
                                <td class="text-center">@item.Size</td>
                                <td class="text-end">@item.RentalPricePerDay.ToString("N0") đ</td>
                            </tr>
                        }
                    </tbody>
                </table>
                <a asp-controller="Product" asp-action="Index" class="btn btn-outline-secondary mt-2">← Tiếp tục chọn đồ</a>
            </div>

            <div class="col-md-4">
                @* --- PHẦN KHUYẾN MÃI --- *@
                <div class="card shadow-sm border-0 mb-3 bg-light">
                    <div class="card-body">
                        <h5 class="card-title fw-bold">Mã khuyến mãi</h5>
                        <div class="input-group">
                            <input type="text" id="promoCode" class="form-control" placeholder="Nhập mã ưu đãi...">
                            <button class="btn btn-primary" type="button" onclick="applyPromo()">Áp dụng</button>
                        </div>
                        <div id="promoMessage" class="mt-2 small"></div>
                    </div>
                </div>

                @* --- TÓM TẮT ĐƠN HÀNG --- *@
                <div class="card shadow-sm border-0">
                    <div class="card-body">
                        <h5 class="card-title fw-bold mb-3">Tóm tắt đơn hàng (3 ngày)</h5>
                        <div class="d-flex justify-content-between mb-2">
                            <span>Tạm tính:</span>
                            <span class="fw-bold">@subTotal.ToString("N0") đ</span>
                        </div>
                        <div class="d-flex justify-content-between mb-2 text-danger">
                            <span>Giảm giá:</span>
                            <span id="discountAmount">- 0 đ</span>
                        </div>
                        <hr />
                        <div class="d-flex justify-content-between mb-4">
                            <span class="h5 fw-bold">Tổng cộng:</span>
                            <span id="totalAmount" class="h5 fw-bold text-success">@subTotal.ToString("N0") đ</span>
                        </div>

                        @* FORM GỬI DỮ LIỆU THANH TOÁN SANG CONTROLLER *@
                        <form asp-action="Checkout" method="post">
                            @* Hai dòng hidden này cực kỳ quan trọng để gửi kèm Khuyến mãi *@
                            <input type="hidden" name="promotionId" id="hiddenPromoId" />
                            <input type="hidden" name="discountAmount" id="hiddenDiscount" value="0" />
                            
                            <button type="submit" class="btn btn-success btn-lg w-100 shadow">
                                Chốt đơn & Thuê ngay
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@* SCRIPT XỬ LÝ KHUYẾN MÃI *@
<script>
    function applyPromo() {
        var code = document.getElementById("promoCode").value;
        var subTotalVal = @subTotal;

        if (!code) {
            alert("Vui lòng nhập mã!");
            return;
        }

        // Gọi hàm xử lý Ajax đến Controller
        fetch(`/RentalContract/ApplyDiscount?promoCode=${code}&subTotal=${subTotalVal}`, {
            method: 'POST'
        })
        .then(response => response.json())
        .then(data => {
            var msg = document.getElementById("promoMessage");
            if (data.success) {
                msg.innerHTML = `<span class="text-success fw-bold">✓ Áp dụng thành công!</span>`;
                
                // 1. Cập nhật số tiền hiển thị trên giao diện
                var discount = data.discountAmount;
                document.getElementById("discountAmount").innerText = "- " + discount.toLocaleString() + " đ";
                document.getElementById("totalAmount").innerText = (subTotalVal - discount).toLocaleString() + " đ";

                // 2. CẬP NHẬT GIÁ TRỊ VÀO FORM ĐỂ GỬI ĐI
                document.getElementById("hiddenPromoId").value = data.promoId;
                document.getElementById("hiddenDiscount").value = discount;
            } else {
                msg.innerHTML = `<span class="text-danger">✗ ${data.message}</span>`;
                // Reset lại giá trị nếu áp dụng mã sai
                document.getElementById("hiddenPromoId").value = "";
                document.getElementById("hiddenDiscount").value = "0";
                document.getElementById("discountAmount").innerText = "- 0 đ";
                document.getElementById("totalAmount").innerText = subTotalVal.toLocaleString() + " đ";
            }
        })
        .catch(err => console.error("Lỗi:", err));
    }
</script>