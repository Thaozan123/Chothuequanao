@model IEnumerable<ChoThueQuanAo.Models.Product>
@using ChoThueQuanAo.Models
@{
    ViewData["Title"] = "Giỏ hàng của bạn";
    var products = Model ?? Enumerable.Empty<Product>();
    var subTotal = products.Sum(p => p.RentalPricePerDay * 3);
    var totalAmount = subTotal;
    var adviceLines = new List<string>();
    if (!products.Any())
    {
        adviceLines.Add("Giỏ hàng trống. Hãy chọn đồ để nhận tư vấn AI phù hợp với sự kiện của bạn.");
    }
    else
    {
        if (products.Count() > 1)
        {
            adviceLines.Add("Bạn đang thuê nhiều sản phẩm, hãy kiểm tra kích cỡ và thời gian trả để tránh phí trễ.");
        }
        else
        {
            var single = products.First();
            adviceLines.Add($"Sản phẩm {single.Name} phù hợp cho những dịp cần vẻ đẹp trang trọng và thoải mái.");
        }

        if (subTotal > 150000)
        {
            adviceLines.Add("Tổng tiền thuê khá cao, bạn nên sử dụng mã khuyến mãi nếu có.");
        }

        if (products.Any(p => p.StockQuantity < 3))
        {
            adviceLines.Add("Một số sản phẩm đang còn ít hàng, nên chốt đơn sớm để giữ được món yêu thích.");
        }
    }
    var cartAdvice = string.Join(" ", adviceLines);
}

<div class="container">
    <h2 class="mb-4"><i class="fas fa-shopping-cart"></i> Giỏ hàng của bạn</h2>

    <div class="row">
        <div class="col-lg-8">
            <div class="card mb-4 border-primary">
                <div class="card-body bg-light">
                    <h5 class="card-title">Tư vấn AI</h5>
                    <p class="card-text">@cartAdvice</p>
                </div>
            </div>
            <!-- Bảng giỏ hàng của bạn -->
            <div class="card mb-4">
                <div class="card-body">
                    <table class="table table-striped">
                        <thead class="table-dark">
                            <tr>
                                <th>Sản phẩm</th>
                                <th>Size mặc định</th>
                                <th>Giá thuê/ngày</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (products.Any())
                            {
                                foreach (var product in products)
                                {
                                    <tr>
                                        <td>@product.Name</td>
                                        <td>@(string.IsNullOrEmpty(product.Size) ? "M" : product.Size)</td>
                                        <td>@product.RentalPricePerDay.ToString("N0") đ</td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="3" class="text-center py-5 text-muted">
                                        Giỏ hàng của bạn hiện đang trống.
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            <a href="@Url.Action("Index", "Product")" class="btn btn-outline-secondary">
                ← Tiếp tục chọn đồ
            </a>
        </div>

        <div class="col-lg-4">
            <!-- Thẻ áp dụng mã khuyến mãi -->
            <div class="card mb-3 p-3">
                <h5 class="mb-3">Mã khuyến mãi</h5>
                <form id="applyVoucherForm">
                    @Html.AntiForgeryToken()
                    <div class="input-group">
                        <input id="voucherCode" name="code" type="text" class="form-control"
                               placeholder="Nhập mã ưu đãi..." />
                        <button id="applyDiscountBtn" type="submit" class="btn btn-primary">
                            Áp dụng
                        </button>
                    </div>
                </form>
                <div id="voucherMessage" class="mt-2"></div>
            </div>

            <div id="promotionAvailableContainer" class="mb-3"></div>

            <div class="card p-3">
                <h5>Tóm tắt đơn hàng (3 ngày)</h5>
                <div class="d-flex justify-content-between">
                    <span>Tạm tính:</span>
                    <strong id="subTotalDisplay" data-value="@subTotal">@subTotal.ToString("N0") đ</strong>
                </div>
                <div class="d-flex justify-content-between text-danger">
                    <span>Giảm giá:</span>
                    <strong id="discountDisplay">- 0 đ</strong>
                </div>
                <hr />
                <div class="d-flex justify-content-between">
                    <span>Tổng cộng:</span>
                    <strong id="totalAmountDisplay" class="text-success">@totalAmount.ToString("N0") đ</strong>
                </div>

                <form id="checkoutForm" asp-action="Checkout" asp-controller="Cart" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="promotionId" id="promotionId" value="" />
                    <input type="hidden" name="discountAmount" id="discountAmount" value="0" />
                    <button type="submit" class="btn btn-success btn-lg w-100 mt-3">
                        Chốt đơn & Thuê ngay
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function formatCurrency(value) {
            return new Intl.NumberFormat('vi-VN').format(value) + ' đ';
        }

        function parseCurrency(value) {
            return Number(value.toString().replace(/[^0-9.-]+/g, '')) || 0;
        }

        async function loadAvailablePromotions() {
            const container = document.getElementById("promotionAvailableContainer");
            try {
                const response = await fetch("/Promotion/Available");
                if (response.ok) {
                    container.innerHTML = await response.text();
                    registerPromoButtons();
                } else {
                    container.innerHTML = "<div class='text-danger'>Không tải được danh sách voucher.</div>";
                }
            } catch {
                container.innerHTML = "<div class='text-danger'>Lỗi tải voucher.</div>";
            }
        }

        function registerPromoButtons() {
            document.querySelectorAll(".apply-promo").forEach(button => {
                button.addEventListener("click", (e) => {
                    e.preventDefault();
                    const code = button.getAttribute("data-code");
                    document.getElementById("voucherCode").value = code;
                    applyVoucher(code);
                });
            });
        }

        async function applyVoucher(code) {
            const tokenInput = document.querySelector("input[name='__RequestVerificationToken']");
            if (!tokenInput) return;
            const token = tokenInput.value;
            const messageBox = document.getElementById("voucherMessage");
            const formData = new URLSearchParams();
            formData.append("__RequestVerificationToken", token);
            formData.append("code", code);

            try {
                const response = await fetch("/Promotion/ApplyVoucher", {
                    method: "POST",
                    headers: {
                        "Content-Type": "application/x-www-form-urlencoded"
                    },
                    body: formData.toString()
                });

                const data = await response.json();
                if (data.success) {
                    const subTotal = parseCurrency(document.getElementById("subTotalDisplay").dataset.value);
                    let discount = 0;
                    if (data.discountType === "Percent") {
                        discount = subTotal * (parseFloat(data.discountValue) / 100);
                    } else {
                        discount = parseFloat(data.discountValue);
                    }

                    discount = Math.max(0, discount);
                    const total = Math.max(0, subTotal - discount);

                    document.getElementById("voucherMessage").innerHTML = `<div class="text-success">${data.message}</div>`;
                    document.getElementById("discountDisplay").textContent = `- ${formatCurrency(discount)}`;
                    document.getElementById("totalAmountDisplay").textContent = formatCurrency(total);
                    document.getElementById("promotionId").value = data.promoId || '';
                    document.getElementById("discountAmount").value = discount;
                } else {
                    document.getElementById("voucherMessage").innerHTML = `<div class="text-danger">${data.message}</div>`;
                }
            } catch {
                document.getElementById("voucherMessage").innerHTML = "<div class='text-danger'>Lỗi áp dụng mã.</div>";
            }
        }

        document.addEventListener("DOMContentLoaded", () => {
            loadAvailablePromotions();

            document.getElementById("applyVoucherForm").addEventListener("submit", function (e) {
                e.preventDefault();
                const code = document.getElementById("voucherCode").value.trim();
                if (code.length > 0) applyVoucher(code);
            });
        });
    </script>
}