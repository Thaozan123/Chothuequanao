@model List<ChoThueQuanAo.ViewModels.CartItemViewModel>

@{
    ViewData["Title"] = "Giỏ hàng của bạn";
    // Mặc định thuê 3 ngày để tính toán ban đầu
    decimal baseTotalPerDay = Model.Sum(x => x.Product.RentalPricePerDay * x.Quantity);
    decimal subTotal = baseTotalPerDay * 3; 
}

<div class="container mt-4">
    <h2 class="text-primary fw-bold mb-4">🛒 Giỏ hàng của bạn</h2>

    @if (Model == null || !Model.Any())
    {
        <div class="alert alert-info shadow-sm">
            <p class="mb-0">Giỏ hàng của bạn đang trống. Hãy quay lại <a asp-controller="Product" asp-action="Index" class="fw-bold">Danh sách sản phẩm</a> để chọn đồ nhé!</p>
        </div>
    }
    else
    {
        <div class="row">
            <div class="col-md-8">
                <table class="table table-hover border shadow-sm bg-white rounded">
                    <thead class="table-dark">
                        <tr>
                            <th>Sản phẩm</th>
                            <th class="text-center">Size</th>
                            <th class="text-center">Số lượng</th>
                            <th class="text-end">Đơn giá/ngày</th>
                            <th class="text-center">Xóa</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>
                                    <div class="d-flex align-items-center">
                                        @if (!string.IsNullOrEmpty(item.Product.ImageUrl))
                                        {
                                            <img src="@item.Product.ImageUrl" class="rounded me-2" style="width: 50px; height: 50px; object-fit: cover;" />
                                        }
                                        <span class="fw-bold">@item.Product.Name</span>
                                    </div>
                                </td>
                                <td class="text-center align-middle">@item.Product.Size</td>
                                <td class="text-center align-middle" style="width: 140px;">
                                    @if(item.Product.StockQuantity <= 0)
                                    {
                                        <span class="text-danger fw-bold">Hết hàng</span>
                                        <form asp-action="UpdateQuantity" method="post" class="d-none">
                                            <input type="hidden" name="productId" value="@item.Product.Id" />
                                            <input type="hidden" name="quantity" value="0" />
                                        </form>
                                    }
                                    else
                                    {
                                        <form asp-action="UpdateQuantity" method="post" class="d-flex justify-content-center">
                                            <input type="hidden" name="productId" value="@item.Product.Id" />
                                            <input type="number" name="quantity" value="@item.Quantity" min="1" max="@item.Product.StockQuantity" class="form-control form-control-sm text-center w-75" onchange="this.form.submit()" title="Còn @item.Product.StockQuantity sản phẩm" />
                                        </form>
                                    }
                                </td>
                                <td class="text-end align-middle">@item.Product.RentalPricePerDay.ToString("N0") đ</td>
                                <td class="text-center align-middle">
                                    <a asp-action="RemoveFromCart" asp-route-productId="@item.Product.Id" class="btn btn-sm btn-outline-danger">
                                        Xóa
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
                <a asp-controller="Product" asp-action="Index" class="btn btn-outline-secondary mt-2">← Tiếp tục chọn đồ</a>
            </div>

            <div class="col-md-4">
                @{
                    var availablePromos = ViewBag.AvailablePromotions as List<ChoThueQuanAo.Models.Promotion> ?? new List<ChoThueQuanAo.Models.Promotion>();
                    decimal cartSubTotal = ViewBag.CartSubTotal ?? 0m;
                }

                <div class="card shadow-sm border-0 mb-3 bg-light">
                    <div class="card-body">
                        <h5 class="card-title fw-bold">Voucher phù hợp</h5>
                        @if (availablePromos.Any())
                        {
                            <div class="list-group mb-2">
                                @foreach (var promo in availablePromos)
                                {
                                    <div class="list-group-item d-flex justify-content-between align-items-start">
                                        <div>
                                            <strong>@promo.Code</strong>
                                            <div class="small text-muted">
                                                @promo.Name • Giảm @((promo.DiscountType == "Percent") ? promo.DiscountValue + "%" : promo.DiscountValue.ToString("N0") + " đ")
                                                @if (promo.MinOrderAmount > 0)
                                                {
                                                    <span>• Tối thiểu @promo.MinOrderAmount.ToString("N0") đ</span>
                                                }
                                            </div>
                                        </div>
                                        <button type="button" class="btn btn-sm btn-outline-primary" onclick="applyPromo('@promo.Code')">Dùng</button>
                                    </div>
                                }
                            </div>
                            <div class="small text-muted">Những mã này đang hợp lệ với đơn hàng hiện tại.</div>
                        }
                        else
                        {
                            <div class="text-muted">Chưa có voucher phù hợp hoặc bạn chưa đăng nhập.</div>
                        }
                    </div>
                </div>

                <div class="card shadow-sm border-0 mb-3 bg-light">
                    <div class="card-body">
                        <h5 class="card-title fw-bold">Mã khuyến mãi</h5>
                        <form id="promoForm">
                            @Html.AntiForgeryToken()
                            <div class="input-group">
                                <input type="text" id="promoCode" class="form-control" placeholder="Nhập mã ưu đãi...">
                                <button class="btn btn-primary" type="button" onclick="applyPromo()">Áp dụng</button>
                            </div>
                        </form>
                        <div id="promoMessage" class="mt-2 small"></div>
                    </div>
                </div>

                @* --- TÓM TẮT ĐƠN HÀNG --- *@
                <div class="card shadow-sm border-0">
                    <div class="card-body">
                        <h5 class="card-title fw-bold mb-3" id="summaryDaysText">Tóm tắt đơn hàng (3 ngày)</h5>
                        
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <span>Số ngày thuê:</span>
                            <input type="number" id="numberOfDays" class="form-control w-25 text-end" value="3" min="1" max="30" onchange="updateDays()" />
                        </div>

                        <div class="d-flex justify-content-between mb-2">
                            <span>Tạm tính:</span>
                            <span id="subTotalAmount" class="fw-bold">@subTotal.ToString("N0") đ</span>
                        </div>
                        <div class="d-flex justify-content-between mb-2 text-danger">
                            <span>Giảm giá:</span>
                            <span id="discountAmount">- 0 đ</span>
                        </div>
                        <hr />
                        <div class="d-flex justify-content-between mb-4">
                            <span class="h5 fw-bold">Tổng cộng:</span>
                            <span id="totalAmount" class="h5 fw-bold text-success">@subTotal.ToString("N0") đ</span>
                        </div>

                        @* FORM GỬI DỮ LIỆU THANH TOÁN SANG CONTROLLER *@
                        <form asp-action="Checkout" method="post">
                            @* Cực kỳ quan trọng để gửi kèm Khuyến mãi & Số ngày *@
                            <input type="hidden" name="promotionId" id="hiddenPromoId" />
                            <input type="hidden" name="discountAmount" id="hiddenDiscount" value="0" />
                            <input type="hidden" name="numberOfDays" id="hiddenDays" value="3" />
                            
                            <button type="submit" class="btn btn-success btn-lg w-100 shadow">
                                Chốt đơn & Thuê ngay
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@* SCRIPT XỬ LÝ KHUYẾN MÃI *@
<script>
    var baseTotalPerDay = @baseTotalPerDay;

    function getSubTotal() {
        var days = parseInt(document.getElementById("numberOfDays").value) || 1;
        return baseTotalPerDay * days;
    }

    function updateDays() {
        var days = parseInt(document.getElementById("numberOfDays").value) || 1;
        if (days < 1) {
            days = 1;
            document.getElementById("numberOfDays").value = 1;
        }

        document.getElementById("hiddenDays").value = days;
        document.getElementById("summaryDaysText").innerText = `Tóm tắt đơn hàng (${days} ngày)`;

        var newSubTotal = baseTotalPerDay * days;
        
        // Cần reset lại mã vì tổng tiền thay đổi (có thể rớt mức MinOrderAmount)
        document.getElementById("promoCode").value = "";
        document.getElementById("promoMessage").innerHTML = "";
        document.getElementById("hiddenPromoId").value = "";
        document.getElementById("hiddenDiscount").value = "0";
        document.getElementById("discountAmount").innerText = "- 0 đ";
        
        document.getElementById("subTotalAmount").innerText = newSubTotal.toLocaleString('vi-VN') + " đ";
        document.getElementById("totalAmount").innerText = newSubTotal.toLocaleString('vi-VN') + " đ";
    }

    function applyPromo(code) {
        var promoCode = code || document.getElementById("promoCode").value;
        var subTotalVal = getSubTotal();

        if (!promoCode) {
            alert("Vui lòng nhập mã!");
            return;
        }

        var tokenInput = document.querySelector("input[name='__RequestVerificationToken']");
        if (!tokenInput) {
            alert("Không tìm thấy token bảo mật. Hãy load lại trang.");
            return;
        }

        var formData = new URLSearchParams();
        formData.append("__RequestVerificationToken", tokenInput.value);
        formData.append("code", promoCode.trim());

        fetch("/Promotion/ApplyVoucher", {
            method: 'POST',
            headers: {
                'Content-Type': 'application/x-www-form-urlencoded'
            },
            body: formData.toString()
        })
        .then(response => response.json())
        .then(data => {
            var msg = document.getElementById("promoMessage");
            if (data.success) {
                msg.innerHTML = `<span class="text-success fw-bold">✓ Áp dụng thành công!</span>`;

                var discount = 0;
                if (data.discountType === "Percent") {
                    discount = subTotalVal * (parseFloat(data.discountValue) / 100);
                } else {
                    discount = parseFloat(data.discountValue);
                }
                discount = Math.max(0, discount);

                document.getElementById("discountAmount").innerText = "- " + discount.toLocaleString('vi-VN') + " đ";
                document.getElementById("totalAmount").innerText = (subTotalVal - discount).toLocaleString('vi-VN') + " đ";
                document.getElementById("hiddenPromoId").value = data.promoId;
                document.getElementById("hiddenDiscount").value = discount;
                document.getElementById("promoCode").value = data.code || promoCode;
            } else {
                msg.innerHTML = `<span class="text-danger">✗ ${data.message}</span>`;
                document.getElementById("hiddenPromoId").value = "";
                document.getElementById("hiddenDiscount").value = "0";
                document.getElementById("discountAmount").innerText = "- 0 đ";
                document.getElementById("totalAmount").innerText = subTotalVal.toLocaleString('vi-VN') + " đ";
            }
        })
        .catch(err => console.error("Lỗi:", err));
    }
</script>