@model List<ChoThueQuanAo.Models.Product>

<h2>Giỏ hàng</h2>

@if (!Model.Any())
{
    <p>Giỏ hàng trống</p>
}
else
{
    <table class="table">
        <tr>
            <th>Tên</th>
            <th>Giá</th>
        </tr>

        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Name</td>
                <td>@item.RentalPricePerDay</td>
            </tr>
        }
    </table>

    <a asp-action="Checkout" class="btn btn-success">
        Thuê tất cả
    </a>
}