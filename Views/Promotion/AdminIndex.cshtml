@model IEnumerable<ChoThueQuanAo.Models.Promotion>

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-dark"><i class="fas fa-tags me-2"></i>Quản lý mã khuyến mãi</h2>
        <a asp-action="Create" class="btn btn-success shadow-sm">
            <i class="fas fa-plus"></i> Tạo mã mới
        </a>
    </div>

    <div class="card shadow-sm">
        <div class="card-body p-0">
            <table class="table table-bordered table-hover mb-0">
                <thead class="table-dark">
                    <tr>
                        <th class="text-center">Tên chương trình</th>
                        <th class="text-center">Mã</th>
                        <th class="text-center">Mức giảm</th>
                        <th class="text-center">Lượt dùng</th>
                        <th class="text-center">Thời gian</th>
                        <th class="text-center">Trạng thái</th>
                        <th class="text-center">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td class="align-middle">@item.Name</td>
                                <td class="align-middle fw-bold text-primary text-center">@item.Code</td>
                                <td class="align-middle text-center">
                                    @(item.DiscountType == "Percent" ? item.DiscountValue.ToString("N0") + "%" : item.DiscountValue.ToString("N0") + "đ")
                                </td>
                                <td class="align-middle text-center">
                                    <span class="badge bg-light text-dark border">@item.UsedCount / @item.UsageLimit</span>
                                </td>
                                <td class="align-middle text-center small">
                                    @item.StartDate.ToString("dd/MM/yy") - @item.EndDate.ToString("dd/MM/yy")
                                </td>
                                <td class="align-middle text-center">
                                    <span class="badge @(item.IsActive && item.EndDate >= DateTime.Now ? "bg-success" : "bg-danger")">
                                        @(item.IsActive && item.EndDate >= DateTime.Now ? "Đang chạy" : "Hết hạn/Tắt")
                                    </span>
                                </td>
                                <td class="align-middle text-center">
                                    <div class="btn-group">
                                        @* --- NÚT SỬA --- *@
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning me-1 shadow-sm">
                                            <i class="fas fa-edit"></i> Sửa
                                        </a>

                                        @* --- NÚT XÓA --- *@
                                        <a asp-action="Delete" asp-route-id="@item.Id" 
                                           class="btn btn-sm btn-danger shadow-sm" 
                                           onclick="return confirm('Bạn có chắc chắn muốn xóa mã @item.Code này không Vân?')">
                                            <i class="fas fa-trash"></i> Xóa
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7" class="text-center py-4 text-muted">Chưa có mã khuyến mãi nào được tạo.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@* Đảm bảo đã có FontAwesome để hiện icon *@
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />