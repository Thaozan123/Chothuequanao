## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# Build results
[Dd]ebug/
[Rr]elease/
x64/
x86/
[Bb]in/
[Oo]bj/

# Visual Studio 2015/2017/2022 cache/options directory
.vs/

# ASP.NET Core
project.lock.json
project.fragment.lock.json
artifacts/

# Files built by Visual Studio
*.ilk
*.meta
*.obj
*.pch
*.pdb
*.pgc
*.pgd
*.rsp
*.sbr
*.tlb
*.tli
*.tlh
*.tmp
*.tmp_proj
*.log
*.vspscc
*.vssscc
.builds

# NuGet Packages
*.nupkg
**/[Pp]ackages/*
!**/[Pp]ackages/build/
*.nuget.props
*.nuget.targets

# SQL Server files (Quan trọng: Không nên đưa file DB lên Git)
*.mdf
*.ldf
*.ndf

# VS Code files
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.code-workspace

# ==========================================================
# PHẦN BỔ SUNG RIÊNG CHO DỰ ÁN CỦA VÂN & YẾN NHI
# ==========================================================

# Chặn file cấu hình Database (để máy mỗi người tự giữ Server riêng)
appsettings.json
appsettings.Development.json

# Chặn thư mục upload ảnh (nếu sau này bạn có chức năng up ảnh sản phẩm)
wwwroot/images/uploads/
wwwroot/lib/

# Các file tạm của Windows
Thumbs.db
desktop.ini